.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 44rpx;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.section {
  margin-bottom: 56rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 22rpx;
}

.empty-text {
  color: #999;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.card {
  background: white;
  border-radius: 28rpx;
  padding: 34rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.event-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.event-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 14rpx;
}

.event-date {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.event-countdown {
  font-size: 32rpx;
  font-weight: bold;
}

.event-countdown.urgent {
  color: #ff4757;
}

.event-countdown.soon {
  color: #ff8c42;
}

.event-countdown.normal {
  color: #ff6b81;
}

.reminder-tag {
  font-size: 22rpx;
  color: #ff6b81;
  background: #fff0f3;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.add-btn {
  margin-top: 16rpx;
  background: #ff6b81;
  color: white;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn::after {
  border: none;
}