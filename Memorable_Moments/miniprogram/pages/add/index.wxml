<view class="page">
  <view class="title">{{pageTitle}}</view>

  <view class="form-card">
    <view class="label">名称</view>

    <input
      class="input"
      placeholder="请输入名称，例如：妈妈生日"
      value="{{name}}"
      bindinput="onNameInput"
    />

    <view class="label">日期</view>

    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="picker">
        {{date || '请选择日期'}}
      </view>
    </picker>

    <view class="label">日历类型</view>

    <picker
      mode="selector"
      range="{{calendarTypeList}}"
      value="{{calendarTypeIndex}}"
      bindchange="onCalendarTypeChange"
    >
      <view class="picker">
        {{calendarTypeList[calendarTypeIndex]}}
      </view>
    </picker>

    <view class="label">备注</view>

    <textarea
      class="textarea"
      placeholder="可选，例如：记得提前准备礼物"
      value="{{remark}}"
      bindinput="onRemarkInput"
      auto-height
    />

    <button class="save-btn" bindtap="onSave">
      保存
    </button>
  </view>
</view>