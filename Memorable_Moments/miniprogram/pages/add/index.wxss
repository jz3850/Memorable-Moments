.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx;
  box-sizing: border-box;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.form-card {
  background: white;
  border-radius: 28rpx;
  padding: 34rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

.input {
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.picker {
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 18rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.save-btn {
  margin-top: 48rpx;
  background: #ff6b81;
  color: white;
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
}

.save-btn::after {
  border: none;
}

.textarea {
  width: 100%;
  min-height: 160rpx;

  background: #f7f7f7;
  border-radius: 18rpx;

  padding: 24rpx;
  box-sizing: border-box;

  font-size: 30rpx;
  line-height: 44rpx;
  color: #333;
}